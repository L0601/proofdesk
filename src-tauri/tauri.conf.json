{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "砚准",
  "version": "0.1.0",
  "identifier": "com.yanzhun.proofdesk",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "砚准 ProofDesk",
        "width": 1440,
        "height": 960,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
